{
  "info": {
    "name": "Colombia Comparte - API CMS",
    "description": "Coleccion de endpoints para el CMS multipais con login JWT y proteccion de rutas",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "countrySlug",
      "value": "colombia"
    },
    {
      "key": "newsSlug",
      "value": "ejemplo"
    },
    {
      "key": "id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "🟢 Health Check",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "🔐 Login correcto",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.collectionVariables.set('token', jsonData.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"superadmin\",\n  \"password\": \"123456\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          }
        },
        {
          "name": "🔑 Forgot Password - Obtener pregunta",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"identifier\": \"superadmin\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/forgot-password"
          }
        },
        {
          "name": "🔄 Reset Password - Restaurar contraseña",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"superadmin\",\n  \"respuesta_seguridad\": \"cms2026\",\n  \"nueva_password\": \"123456789\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/reset-password"
          }
        },
        {
          "name": "🔐 Change Password - Cambiar contraseña propia",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password_actual\": \"123456\",\n  \"nueva_password\": \"123456789\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/change-password"
          }
        },
        {
          "name": "❓ Update Security Question - Cambiar pregunta de seguridad",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pregunta_seguridad\": \"¿Cuál es tu ciudad favorita?\",\n  \"respuesta_seguridad\": \"Tunja\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/security-question"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "👤 Get Profile (me)",
